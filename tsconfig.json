{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["node"],
    "typeRoots": ["../pi-mcp-adapter/node_modules/@types"],
    "rootDir": ".",
    "outDir": "dist",
    "resolveJsonModule": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@mariozechner/pi-coding-agent": [
        "../pi-agent-router/node_modules/@mariozechner/pi-coding-agent/dist/index.d.ts"
      ]
    }
  },
  "include": [
    "index.ts",
    "src/**/*.ts",
    "test/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "debug"
  ]
}
